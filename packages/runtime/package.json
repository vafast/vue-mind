{
  "name": "@vue-mind/runtime",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external vue --external vue-router --external @vue-mind/shared --clean"
  },
  "peerDependencies": {
    "vue": ">=3.3.0",
    "vue-router": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vue-router": { "optional": true }
  },
  "dependencies": {
    "@vue-mind/shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vafast/vue-mind.git",
    "directory": "packages/runtime"
  }
}
