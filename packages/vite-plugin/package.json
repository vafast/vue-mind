{
  "name": "@vue-mind/vite-plugin",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external @vue-mind/shared --clean",
    "dev": "tsup src/index.ts --format esm --dts --external @vue-mind/shared --watch"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.5.0",
    "@vue/compiler-dom": "^3.5.0",
    "@vue-mind/shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
